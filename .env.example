# AgentiCMS environment — copy to `.env` and fill in real values.
# `.env` is gitignored; never commit real secrets.

# --- Required secrets (no defaults; the stack refuses to start without them) ---

# Postgres password for the `agenticms` database user.
#   openssl rand -base64 24
POSTGRES_PASSWORD=

# HMAC secret for signing/verifying admin JWT access tokens. Long & random.
#   openssl rand -hex 48
JWT_SECRET=

# Shared key the website (nginx) container uses to call admin's internal
# /api/config endpoint. Long & random; different from JWT_SECRET.
#   openssl rand -hex 48
INTERNAL_API_KEY=

# Password for the initial admin user, created on FIRST boot. There is NO
# default — the seed fails closed (the container exits with an error) rather
# than creating a publicly-known admin. Required for the first deployment;
# once the admin exists it is no longer consulted, and you should rotate it
# from inside the app. Use a strong value.
#   openssl rand -base64 24
ADMIN_PASSWORD=

# --- Optional ---

# Email/login of the initial admin user (first boot only). Defaults to
# admin@agenticms.local if unset.
# ADMIN_EMAIL=admin@agenticms.local

# Comma-separated origin allowlist for credentialed CORS to the admin API.
# Leave empty for the standard same-origin nginx-proxy setup.
# e.g. WEBSITE_URL=https://example.com,https://staging.example.com
WEBSITE_URL=

# Auth brute-force limiter (per client IP). Defaults: 10 / "10 minutes".
# LOGIN_RATE_MAX=10
# LOGIN_RATE_WINDOW=10 minutes

# Public submissions endpoint guards. Defaults shown.
# SUBMISSIONS_RATE_MAX=5
# SUBMISSIONS_RATE_WINDOW=10 minutes
# SUBMISSIONS_MIN_FILL_MS=2500
