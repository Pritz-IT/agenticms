{
  "name": "agenticms-admin",
  "version": "0.1.0",
  "description": "AgentiCMS admin API and build control plane.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pritz-IT/agenticms.git",
    "directory": "admin"
  },
  "bugs": {
    "url": "https://github.com/Pritz-IT/agenticms/issues"
  },
  "homepage": "https://github.com/Pritz-IT/agenticms#readme",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:server && npm run build:seed",
    "build:server": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --external:@prisma/client --external:bcrypt --external:esbuild --external:fsevents --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "build:seed": "esbuild prisma/seed.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/seed.js --external:@prisma/client --external:bcrypt --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "build:tsc": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:sync-assets": "tsx scripts/sync-assets.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.0.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "esbuild": "^0.28.0",
    "prisma": "^5.22.0",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/uuid": "^10.0.0",
    "chokidar": "^3.6.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "uuid": "^11.1.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "fast-uri": "3.1.2"
  }
}
